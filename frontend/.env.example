# Clerk Authentication
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key

# Backend API URL
VITE_API_URL=http://localhost:3000/api

# Stream API Key (for video/chat)
VITE_STREAM_API_KEY=your_stream_api_key

# WebSocket URL for live cursor/collaborative editing (PRODUCTION ONLY)
# For local development, this is optional (defaults to ws://localhost:3000/yjs)
# For production deployment, set this to your backend WebSocket URL
# Example: wss://your-backend.onrender.com
VITE_YJS_WS_URL=wss://your-backend-url.com
